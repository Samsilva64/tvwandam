generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "mysql"
}

enum UserRole {
  ADMIN
  EDITOR
}

enum LiveStreamStatus {
  LIVE
  OFFLINE
  SCHEDULED
}

enum PostCategory {
  CULTURA
  MUSICA
  EVENTOS
  ENTREVISTAS
}

enum PartnerPackageType {
  BRONZE
  SILVER
  GOLD
  PLATINUM
  LOCAL
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         UserRole @default(EDITOR)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Program {
  id             String          @id @default(cuid())
  title          String
  description    String
  coverImage     String
  category       String
  isManuallyEdited Boolean       @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  episodes       Episode[]
  scheduleItems  ScheduleItem[]
}

model ScheduleItem {
  id        String   @id @default(cuid())
  date      DateTime
  startTime String
  endTime   String
  programId String
  program   Program  @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@index([date])
  @@index([programId])
}

model Episode {
  id          String    @id @default(cuid())
  programId   String
  program     Program   @relation(fields: [programId], references: [id], onDelete: Cascade)
  title       String
  description String
  videoUrl    String
  thumbnail   String
  duration    String
  views       Int       @default(0)
  isManuallyEdited Boolean @default(false)
  publishedAt DateTime
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  artists     Artist[]  @relation("EpisodeArtists")

  @@index([programId])
  @@index([publishedAt])
}

model LiveStream {
  id          String           @id @default(cuid())
  title       String
  description String?
  status      LiveStreamStatus @default(OFFLINE)
  embedUrl    String
  scheduledAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([status])
}

model Post {
  id        String       @id @default(cuid())
  title     String
  content   String
  image     String?
  category  PostCategory
  slug      String       @unique
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([category])
  @@index([createdAt])
}

model Artist {
  id          String    @id @default(cuid())
  name        String
  bio         String
  image       String
  socialLinks Json
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  episodes    Episode[] @relation("EpisodeArtists")

  @@index([name])
}

model Partner {
  id          String             @id @default(cuid())
  name        String
  logo        String
  website     String?
  packageType PartnerPackageType @default(LOCAL)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}
